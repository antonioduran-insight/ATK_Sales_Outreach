# AI Token King — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ⚠  Never commit .env to git — it contains secret keys.

# ── REQUIRED FOR WORKSHOP ──────────────────────────────────────────────

# AI Token King API Key — used to generate personalised message drafts
# Workshop participants: Antonio will give you this key.
ATK_API_KEY=
ATK_API_BASE=https://api.aitokenking.com.tw/api
ATK_MODEL=Sonnet

# Apify API Token — used to scrape leads from LinkedIn Sales Navigator
# Get it at: https://console.apify.com → Settings → Integrations → API tokens
APIFY_TOKEN=


# ── OPTIONAL — SKIP FOR WORKSHOP ──────────────────────────────────────

# LinkedIn session cookie — only needed for some scrapers (not required for workshop)
# To get it: LinkedIn tab → F12 → Application → Cookies → linkedin.com → li_at
LINKEDIN_LI_AT=

# Asana CRM integration — used for dedup across team accounts (skip for workshop)
# run_pipeline.py uses --skip-asana-dedup automatically, so this is not needed.
ASANA_TOKEN=
ASANA_PROJECT_GID=

# Make.com Webhook — used to trigger automated sending via Phantombuster (skip for workshop)
MAKE_WEBHOOK_URL=

# Slack Webhook — used for Hot Lead alerts (skip for workshop)
SLACK_WEBHOOK_URL=

# Expandi campaign automation (skip for workshop)
EXPANDI_API_KEY=
EXPANDI_API_SECRET=
